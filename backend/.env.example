# Copy to .env and fill in values. Never commit .env.

PORT=5000
MONGODB_URI=mongodb_connection_string_here

# Public URL of the React app (production). For local dev, RSVP/reset links prefer your
# browser Origin when it is localhost — or set LINK_BASE_URL explicitly.
FRONTEND_URL=http://localhost:5173

# Optional: force links in emails (RSVP, password reset, admin invite) to this base URL.
# Example when FRONTEND_URL is a public IP but you test on localhost:
# LINK_BASE_URL=http://localhost:5173

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@wedguest.local
ADMIN_PASSWORD=Admin@123

# Gmail: 2FA + App password for EMAIL_PASS
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_ALLOW_SELF_SIGNED=false
